@model HomeViewModel

@{
    ViewData["Title"] = "Home";
}

<h1 class="mb-4">Home</h1>

<div class="row g-3 mb-4">
    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-body">
                <h5 class="card-title">Total articole</h5>
                <p class="display-6 mb-0">@Model.TotalArticles</p>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-body">
                <h5 class="card-title">Total categorii</h5>
                <p class="display-6 mb-0">@Model.TotalCategories</p>
            </div>
        </div>
    </div>
</div>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">Cele mai recente 3 articole</h2>
    <a asp-controller="Articles" asp-action="Index" class="btn btn-outline-primary">Vezi toate articolele</a>
</div>

@if (!Model.LatestArticles.Any())
{
    <div class="alert alert-info">Nu exista articole.</div>
}
else
{
    <div class="row g-3">
        @foreach (var article in Model.LatestArticles)
        {
            <div class="col-md-4">
                <div class="card h-100">
                    @if (!string.IsNullOrWhiteSpace(article.ImagePath))
                    {
                        <img src="@article.ImagePath" class="card-img-top" alt="@article.Title" style="height: 220px; object-fit: cover;" />
                    }
                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title">@article.Title</h5>
                        <p class="card-text text-muted mb-2">@article.CategoryName · @article.AuthorName</p>
                        <p class="card-text">@(article.Content.Length > 120 ? article.Content[..120] + "..." : article.Content)</p>
                        <div class="mt-auto">
                            <a asp-controller="Articles" asp-action="Details" asp-route-id="@article.Id" class="btn btn-outline-primary btn-sm">Detalii</a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}
